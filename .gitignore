# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Environment files (CRITICAL: never commit secrets) ──
*.env
*.env.*
.env
.env.local
.env.production
.env.staging
backend/.env
frontend/.env

# ── IDE and editors ──
.idea/
.vscode/

# ── Dependencies ──
node_modules/
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Testing ──
/coverage

# ── Next.js ──
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# ── Production builds ──
/build
dist/

# ── Credentials & tokens ──
*token.json*
*credentials.json*
*.pem

# ── Logs and debug ──
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# ── System files ──
.DS_Store
Thumbs.db

# ── Python ──
__pycache__/
*.pyc
venv/
.venv/

# ── Development tools ──
chainlit.md
.chainlit
.ipynb_checkpoints/

# ── Deployment ──
.vercel

# ── Archive files ──
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# ── Build caches ──
.cache/
frontend/node_modules/.cache/
frontend/node_modules/.cache/default-development/16.pack
frontend/node_modules/.cache/default-development/0.pack
frontend/node_modules/.cache/default-development/9.pack
frontend/node_modules/.cache/default-development/19.pack
frontend/node_modules/.cache/default-development/5.pack
frontend/node_modules/.cache/default-development/6.pack
frontend/node_modules/.cache/default-development/12.pack
frontend/node_modules/.cache/default-development/1.pack
