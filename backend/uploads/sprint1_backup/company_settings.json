[{"settings_id": "settings_b964ad8deffa", "user_id": "test_user_96e42091", "business_name": "Officina Metallo SRL", "partita_iva": "IT99887766554", "condizioni_vendita": "Pagamento a 30gg. Foro competente Roma. Test Playwright", "updated_at": "2026-02-28 07:26:37.643000", "logo_url": "", "address": "", "bank_details": {"bank_name": "", "iban": "", "bic_swift": null}, "cap": "", "city": "", "codice_fiscale": "", "country": "IT", "province": "", "regime_fiscale": "RF01", "tenant_id": "default"}, {"settings_id": "settings_69b4d6bc1987", "user_id": "user_97c773827822", "business_name": "Steel Project Design Srls", "partita_iva": "IT02042850897", "codice_fiscale": "IT02042850897", "regime_fiscale": "RF01", "address": "Via dei Pioppi n. 11", "cap": "40010", "city": "Sala Bolognese", "province": "BO", "country": "IT", "email": "info@steelprojectdesign.it", "pec": "steelprojectdesign@legalmail.it", "website": "www.steelprojectdesign.it", "bank_details": {"bank_name": "Monte paschi di Siena", "iban": "IT54S0103084700000001705594", "bic_swift": null}, "logo_url": "data:image/png;base64,", "condizioni_vendita": "1 – Premessa\nAi fini del presente contratto i termini elencati qui di seguito avranno il seguente significato: Steel Project Design Srls: Steel Project Design Srls con sede legale in via dei Pioppi n. 11- 40010 Padulle BO). Acquirente: ogni persona fisica o giuridica o altro ente che acquisti o si impegni ad acquistare dalla Steel Project Design Srls i propri prodotti. Prodotti: ogni bene che sia commercializzato dalla Steel Project Design Srls. \n\n2 - Condizioni di fornitura\na) Merce resa f.co Vs. cantiere/ abitazione\nb) Posa in opera: come descritto\nc) Consegna: 75/90 giorni dalla data di accettazione (il termine di consegna decorre dalla data di versamento dell’acconto).\nd) I tempi di consegna sono indicativi e la mancata o ritardata consegna, di parte o di tutta la commessa, non potrà per nessun motivo dar luogo a rivalsa, né diritto ad esigere indennizzi, salvo diverse condizioni scritte ed accettate dalla società.\ne) Finitura: come descritto\nf) Pagamento: Acconto del 40% all'ordine - saldo a fine lavori pagamento da effettuarsi entro 7 giorni.\ng) Validità offerta: 15 giorni dalla data di emissione per l'intero importo dei lavori (no frazionati)\n\n3 - Oneri a carico del cliente\na) Verifica dettagliata dei prodotti offerti\nb) Verifica presso gli enti di competenza della necessità di autorizzazione per l’installazione\n\n4 - Esclusioni dal preventivo: \nsono da ritenersi escluse dal preventivo di montaggio, le ore di fermo cantiere dovute ad imprevisti quali:\n-Trasporto se no nespressamente indicato,\n-Scarico e smistamento ai fori,\n-Eventuale scarico e distribuzione ai piani del materiale se non espressamente indicato,\n- Eventuali opere murarie,\n-Eventuali modifiche alle posizioni successive alla conferma d'ordine,\n-Eventuale necessità di fornitura di coprifili una volta eseguitoil rilievo esecutivo,\n-Eventuali variazioni della luce foro riscontrate al momento dei rilievi esecutivi,\n-Impalcature,ponteggie mezzi di sollevamento,\n-Energia elettrica e forza motrice,\n- Agibilità nella zona di lavoro,\n-Protezione di eventuali impianti e strutture deteriorabili adiacenti alla zona di lavoro,\n-Oneri per occupazione suolo pubblico,\n-Oneri pe reventuali permessi accesso centro storico e/o altre zone ad accesso limitato,\n- Custodia dei materiali incantiere,\n-Pulizia degli infissi,\n- La posa se non espressamente indicata,\n-Eventuale smontaggio e smaltimento infissi esistenti se non espressamente indicato,\n- Ogni altro servizio e materiale non espressamente indicato,\n- Smaltimento di imballi e materiali di risulta, fatto salvonell'area di cantiere nonci sia idoneo contenitore\n\n5 - Pagamenti\na) La mancata effettuazione di un pagamento, anche parziale, entro i termini concordati, autorizza la Steel Project Design Srls a sospendere ogni consegna, anche se già in corso e anche se non direttamente connessa con il contratto non onorato. Sarà facoltà della Steel Project Design Srls subordinare la consegna della merce al pagamento di ogni fattura non ancora saldata.\nb) Il mancato rispetto dei termini di pagamento, anche se relativo ad una sola rata o scadenza da parte dell’acquirente, determinerà l’automatica risoluzione del contratto per responsabilità dell’acquirente e, in caso di concordato pagamento rateizzato, l’automatica esigibilità dell’intero importo ancora dovuto senza necessità di alcuna comunicazione.\nc) In caso di pagamento dilazionato, la merce si intende di proprietà della Ditta venditrice, sino l completo pagamento di essa, con espresso richiamo alle norme degli art. 1523 e seguenti del Codice Civile. Qualora la compratrice si rendesse inadempiente alle scadenze stabilite la Ditta venditrice avrà facoltà di prendere il materiale su cui esiste la riserva di proprietà senza bisogno di pronunzia giudiziale e con diritto di trattenere i pagamenti ricevuti in conto risarcimento danni e compreso per l'uso del materiale.\nd) In caso di ritardo di pagamento l’Acquirente sarà tenuto a riconoscere alla Steel Project Design Srls il tasso degli interessi maturati in base alla Direttiva Europea n. 2000/35 recepita in Italia con D.L n. 231/2002\ne) Se per responsabilità del cliente la merce non verrà ritirata entro 5 gg dalla data prevista saranno addebitati per lo stoccaggio euro 15,00 +IVA a bancale per ogni giorno di ritardo.\n\n6 - Garanzia\na) È esclusa la garanzia per i vizi dei prodotti venduti. Eventuali contestazioni o reclami in ordine all’esecuzione del contratto, ivi compresi vizi della merce, vanno comunicati per iscritto, a mezzo raccomandata A/R alla Steel Project Design Srls entro otto giorni dal ricevimento/montaggio della merce. Difformità o vizi della merce, solo se espressamente riconosciuti ed autorizzati per iscritto dalla Steel Project Design Srls, attribuiscono all’acquirente il solo diritto alla restituzione merce effettivamente difettosa. Eventuali spese di restituzione e sostituzione saranno ad esclusivo carico dell’acquirente.\n\n7 - Varianti in corso d’opera\nb) Le merci o le varianti richieste in corso d’opera verranno preventivate ed eseguite dopo conferma scritta del Committente.\n\n8 - Controversie\nLuogo dell’adempimento dell’obbligazione è sempre la sede della Steel Project Design Srls. Ogni controversia che dovesse insorgere fra le parti in ordine alla validità, interpretazione applicazione ed esecuzione del presente contratto.\n\n9 - Foro competente\nForo competente Bologna (BO)\n\nFirma e timbro per accettazione data di accettazione___/___/___\n(legale rappresentante)\n__________________________\nAi sensi e per gli effetti dell’Art. 1341 e segg. Del Codice Civile, il sottoscritto Acquirente dichiara di aver preso specifica, precisa e dettagliata visione di tutte le disposizioni del contratto qui di seguito riportate: 1 Premessa; 2 Condizioni di fornitura; 3 Oneri a carico del cliente; 4 Esclusioni dal preventivo; 5 Pagamenti; 6 Garanzia; 7 Varianti in corso d’opera; 8 Controversie e di approvarle integralmente senza alcuna riserva.\n\n_____________________, lì ______________________\n\nFirma e timbro (il legale rappresentante)\n_____________________________\n", "updated_at": "2026-03-24 06:56:09.753000", "aruba_password": "", "aruba_sandbox": true, "aruba_username": "", "certificato_en1090_numero": "1234-CPR-2024-IT", "certificato_en13241_numero": "", "classe_esecuzione_default": "", "ente_certificatore": "RINA Services S.p.A.", "ente_certificatore_numero": "0474", "fic_access_token": "", "fic_company_id": "", "firma_digitale": "", "responsabile_nome": "Ing. Marco Rossi", "ruolo_firmatario": "Responsabile Tecnico / Legale Rappresentante", "bank_accounts": [{"account_id": "ba_1772521165743", "bank_name": "Monte dai paschi di Siena", "iban": "IT73E0103084700000001685911", "bic_swift": "", "intestatario": "Steel Project Design S.R.L.S.", "predefinito": true}, {"account_id": "ba_1772521286530", "b